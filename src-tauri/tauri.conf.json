{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Monoid",
  "version": "0.1.2-1",
  "identifier": "com.zimbler.monoid",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Monoid",
        "width": 1220,
        "height": 840,
        "minWidth": 1080,
        "minHeight": 760,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "icons/Assets.car": "Assets.car"
    },
    "macOS": {}
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZBNzJGNTA5NDI2QjM3OUUKUldTZU4ydENDZlZ5YWdTdFg3ZzdWRHJPZ3gyYXF5b2lnVERSQjk3bGxKWGI3V3pLZjAxYUxETmUK",
      "endpoints": [
        "https://github.com/srgrn/monoid/releases/latest/download/latest.json"
      ]
    }
  }
}
