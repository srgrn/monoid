{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Monoid",
  "version": "0.1.2.2",
  "identifier": "com.zimbler.monoid",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Monoid",
        "width": 1220,
        "height": 840,
        "minWidth": 1080,
        "minHeight": 760,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
